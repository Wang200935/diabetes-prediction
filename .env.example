# Runtime mode
APP_ENV=production

# Public site metadata
APP_TITLE=糖尿病風險評估中心
APP_VERSION=1.0.0
APP_SUMMARY="Health risk inference service for diabetes assessment"

# Bind address for uvicorn
APP_BIND_HOST=127.0.0.1
APP_BIND_PORT=8320

# API docs exposure
APP_DOCS_ENABLED=false

# Network and proxy rules
APP_ALLOWED_ORIGINS=https://your-domain.example,https://www.your-domain.example
APP_ALLOWED_HOSTS=your-domain.example,www.your-domain.example,127.0.0.1,localhost
APP_ALLOW_CREDENTIALS=false

# Prediction resource controls
PREDICT_CONCURRENCY_LIMIT=4
PREDICT_ACQUIRE_TIMEOUT_SECONDS=0.25
PREDICT_EXEC_TIMEOUT_SECONDS=8
PREDICT_RATE_LIMIT_WINDOW_SECONDS=60
PREDICT_RATE_LIMIT_MAX_REQUESTS=600

# Artifact locations
APP_ARTIFACT_DIR=/opt/health-project/shared/artifacts
APP_MODEL_BUNDLE_PATH=/opt/health-project/shared/artifacts/model_bundle.joblib
APP_MODEL_METADATA_PATH=/opt/health-project/shared/artifacts/model_metadata.json
APP_FEATURE_SCHEMA_PATH=/opt/health-project/shared/artifacts/feature_schema.json

# Local dataset path for retraining on Raspberry Pi if needed
LOCAL_DATASET_DIR=/opt/health-project/shared/dataset

# Security header overrides (optional)
APP_PREDICTION_CACHE_CONTROL="no-store, max-age=0"
APP_PREDICTION_PRAGMA=no-cache
